{
  "$schema": "./node_modules/renovate/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeMinor",
    ":label(deps)",
    ":semanticCommitTypeAll(deps)",
    ":semanticCommitScopeDisabled",
    ":timezone(Asia/Tokyo)"
  ],
  "platformAutomerge": true,
  "branchPrefix": "deps/",
  "schedule": [
    "after 10:00 before 18:00 every weekday"
  ],
  "ignorePaths": [
    "**/node_modules/**"
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "ignoreDeps": ["postgres", "mysql"]
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "automerge": true
    },
    {
      "groupName": "byethrow packages",
      "matchSourceUrls": [
        "https://github.com/praha-inc/byethrow"
      ]
    },
    {
      "groupName": "logtape packages",
      "matchSourceUrls": [
        "https://github.com/dahlia/logtape"
      ]
    },
    {
      "groupName": "PrAha oxlint config packages",
      "matchSourceUrls": [
        "https://github.com/praha-inc/oxlint-config"
      ]
    }
  ]
}

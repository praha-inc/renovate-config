{
  "$schema": "./node_modules/renovate/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeMinor",
    ":label(deps)",
    ":semanticCommitTypeAll(deps)",
    ":semanticCommitScopeDisabled",
    ":timezone(Asia/Tokyo)"
  ],
  "platformAutomerge": true,
  "branchPrefix": "deps/",
  "schedule": [
    "after 10:00 before 18:00 every weekday"
  ],
  "ignorePaths": [
    "**/node_modules/**"
  ],
  "toolSettings": {
    "nodeMaxMemory": 1536
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "ignoreDeps": ["postgres", "mysql"]
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "automerge": true
    },
    {
      "groupName": "conform packages",
      "matchPackagePrefixes": [
        "@conform-to/"
      ]
    },
    {
      "groupName": "envelop packages",
      "matchPackagePrefixes": [
        "@envelop/"
      ]
    },
    {
      "groupName": "logtape packages",
      "matchPackagePrefixes": [
        "@logtape/"
      ]
    },
    {
      "groupName": "pothos packages",
      "matchPackagePrefixes": [
        "@pothos/"
      ]
    },
    {
      "groupName": "PrAha eslint config packages",
      "matchPackagePrefixes": [
        "@praha/eslint-config-"
      ]
    }
  ]
}
